{
  "name": "rivmux-workspace",
  "description": "Rivmux is a modern browser video player solution for low-latency FLV and MPEG-TS streams.",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "index.js",
  "keywords": [],
  "author": "yangxu52",
  "scripts": {
    "build": "pnpm run build:crates && pnpm run build:packages",
    "build:release": "pnpm run clean && pnpm run build:wasm && pnpm run build:packages",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "build:crates": "cargo build --workspace",
    "build:wasm": "pnpm --filter @rivmux/transmux-core run build:release",
    "test": "pnpm run test:packages && pnpm run test:workspace && pnpm run test:crates",
    "test:ci": "pnpm run test:packages && pnpm run test:crates",
    "test:packages": "pnpm -r --filter './packages/*' run test",
    "test:crates": "cargo test --workspace",
    "test:workspace": "pnpm run build && vitest run --config vitest.config.ts",
    "clean": "pnpm -r --if-present run clean",
    "typecheck": "tsc -b && cargo check --workspace",
    "clippy": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "format": "prettier --write . && cargo fmt --all",
    "format:check": "prettier --check . && cargo fmt --all --check",
    "release": "commit-and-tag-version && cargo update --offline",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@rivmux/transmux-core": "workspace:*",
    "@vitest/browser-playwright": "catalog:",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.62.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
