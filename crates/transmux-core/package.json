{
  "name": "@rivmux/transmux-core",
  "version": "0.3.0",
  "description": "Private TypeScript workspace wrapper for the Rivmux transmux WASM core.",
  "homepage": "https://github.com/yangxu52/Rivmux/tree/main/crates/transmux-core",
  "bugs": {
    "url": "https://github.com/yangxu52/Rivmux/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/Rivmux.git",
    "directory": "crates/transmux-core"
  },
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./dist/rivmux_transmux_core.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/rivmux_transmux_core.d.ts",
      "import": "./dist/rivmux_transmux_core.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/rivmux_transmux_core.js",
  "types": "./dist/rivmux_transmux_core.d.ts",
  "scripts": {
    "build": "wasm-pack build --no-opt --target web --out-dir dist --out-name rivmux_transmux_core ../../crates/transmux-core",
    "build:release": "wasm-pack build --release --target web --out-dir dist --out-name rivmux_transmux_core ../../crates/transmux-core",
    "clean": "rimraf dist node_modules/.tmp",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0",
    "pnpm": ">=10.0.0"
  }
}
