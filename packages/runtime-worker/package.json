{
  "name": "@rivmux/runtime-worker",
  "version": "0.3.0",
  "description": "Dedicated Worker runtime package for Rivmux.",
  "homepage": "https://www.npmjs.com/package/@rivmux/runtime-worker",
  "bugs": {
    "url": "https://github.com/yangxu52/Rivmux/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangxu52/Rivmux.git",
    "directory": "packages/runtime-worker"
  },
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @rivmux/transmux-core run build && tsdown",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "clean": "rimraf dist node_modules/.tmp"
  },
  "dependencies": {
    "@rivmux/protocol": "workspace:*"
  },
  "devDependencies": {
    "@rivmux/transmux-core": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0",
    "pnpm": ">=10.0.0"
  }
}
