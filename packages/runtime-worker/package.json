{
  "name": "@rivmux/runtime-worker",
  "version": "0.0.1",
  "description": "Dedicated Worker runtime package for Rivmux.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @rivmux/transmux-core run build && tsdown",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "clean": "rimraf dist node_modules/.tmp"
  },
  "dependencies": {
    "@rivmux/transmux-core": "workspace:*",
    "@rivmux/protocol": "workspace:*"
  },
  "devDependencies": {
    "rolldown-plugin-wasm": "^0.3.2",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0",
    "pnpm": ">=10.0.0"
  }
}
